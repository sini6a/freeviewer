# ── Server ────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

PORT=5000
DEBUG=false

# Set to false only if running behind an HTTPS reverse proxy (nginx/caddy)
SESSION_COOKIE_SECURE=true

# ── MySQL ─────────────────────────────────────────────────────────────────────
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=freeviewer
MYSQL_PASSWORD=yourpassword
MYSQL_DATABASE=freeviewer

# ── Agent download (/win) ─────────────────────────────────────────────────────
# Format: username/repository  e.g. john/freeviewer
GITHUB_REPO=

# ── Pairing ───────────────────────────────────────────────────────────────────
PAIRING_CODE_LENGTH=6
PAIRING_EXPIRY_MINUTES=10
